{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DavidH-Creation/mandrama-production-pipeline/schemas/shot-plan.schema.json",
  "title": "Shot Plan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "project_info": {
      "allOf": [
        { "$ref": "./common.schema.json#/$defs/projectEpisode" },
        {
          "type": "object",
          "properties": {
            "total_scenes": { "type": "integer", "minimum": 0 },
            "total_shots": { "type": "integer", "minimum": 0 },
            "estimated_duration_sec": { "type": "integer", "minimum": 0 }
          },
          "required": ["total_scenes", "total_shots", "estimated_duration_sec"]
        }
      ]
    },
    "emotional_curve": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "shot_ref": { "$ref": "./common.schema.json#/$defs/shotId" },
          "emotion_intensity": { "$ref": "./common.schema.json#/$defs/score1to5" },
          "note": { "type": "string" }
        },
        "required": ["shot_ref", "emotion_intensity"]
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "scene_id": { "$ref": "./common.schema.json#/$defs/sceneId" },
          "scene_name": { "type": "string" },
          "location_ref": { "$ref": "./common.schema.json#/$defs/locationId" },
          "characters_present": {
            "type": "array",
            "items": { "$ref": "./common.schema.json#/$defs/characterId" }
          },
          "scene_mood": { "type": "string" },
          "shots": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "shot_id": { "$ref": "./common.schema.json#/$defs/shotId" },
                "duration_sec": { "type": "number", "minimum": 0 },
                "shot_type": { "type": "string" },
                "framing": { "type": "string" },
                "camera_move": { "type": "string" },
                "depth_of_field": { "type": "string" },
                "characters": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "id": { "$ref": "./common.schema.json#/$defs/characterId" },
                      "outfit": { "$ref": "./common.schema.json#/$defs/outfitId" },
                      "expression": { "type": "string" },
                      "position": { "type": "string" },
                      "action": { "type": "string" },
                      "gaze_direction": { "type": "string" }
                    },
                    "required": ["id"]
                  }
                },
                "content_description": { "type": "string" },
                "dialogue": { "type": "string" },
                "sfx_note": { "type": "string" },
                "emotion_intensity": { "$ref": "./common.schema.json#/$defs/score1to5" },
                "emotion_note": { "type": "string" },
                "transition_to_next": { "type": "string" }
              },
              "required": ["shot_id", "duration_sec", "content_description", "emotion_intensity"]
            }
          }
        },
        "required": ["scene_id", "location_ref", "shots"]
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_shots": { "type": "integer", "minimum": 0 },
        "close_up_ratio": { "type": "number", "minimum": 0 },
        "mid_ratio": { "type": "number", "minimum": 0 },
        "wide_ratio": { "type": "number", "minimum": 0 },
        "average_shot_duration": { "type": "number", "minimum": 0 },
        "longest_shot_sec": { "type": "number", "minimum": 0 },
        "shortest_shot_sec": { "type": "number", "minimum": 0 },
        "estimated_total_duration_sec": { "type": "number", "minimum": 0 }
      }
    }
  },
  "required": ["project_info", "scenes"]
}
